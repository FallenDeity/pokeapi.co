{
    "printWidth": 120,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "es5",
    "tabWidth": 2,
    "bracketSpacing": false,
    "arrowParens": "always",
    "plugins": [
        "prettier-plugin-astro",
        "prettier-plugin-tailwindcss",
        "prettier-plugin-tailwindcss-canonical-classes"
    ]
}
