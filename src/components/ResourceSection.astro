---
import { Code } from '@astrojs/starlight/components'
import { marked } from 'marked'
import ApiExplorer from './ApiExplorer.astro'
const { data, playground = true } = Astro.props
---

{
  data.map((obj, index) => (
    <section>
      <h3 class="mt-12" id={obj.name}>
        {obj.name}
        <span class="font-light opacity-80"> (Endpoint)</span>
      </h3>

      <!-- <p>{marked.parse(obj.description)}</p> -->
      {obj.description && <p set:html={marked.parse(obj.description)}></p>}

      <div>
        {
          obj.exampleResponse && obj.exampleRequest ? (
            playground ? (
              <ApiExplorer
                endpoint={obj.exampleRequest.split('/')[2]}
                exampleRequest={obj.exampleRequest}
                exampleResponse={JSON.parse(JSON.stringify(obj.exampleResponse, null, 2).replaceAll("$BASE_URL", "https://pokeapi.co/api"))}
              />
            ) : (
              <Code
                code={JSON.stringify(obj.exampleResponse, null, 2).replaceAll(
                  "$BASE_URL",
                  "https://pokeapi.co/api"
                )}
                lang="json"
                title={"GET https://pokeapi.co/api" + obj.exampleRequest}
              />
            )
          ) : null
        }
      </div>

      {
        obj.responseModels.map((model, index) => (
          <h4 id={model.name}>
            {model.name}
            <span class="font-light opacity-80"> (Type)</span>
          </h4>
          <table class="table [&_tr:hover]:bg-[unset]">
            <thead>
              <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Type</th>
              </tr>
            </thead>
            <tbody>
              {
                model.fields.map((field, index) => (
                  <tr class="border-b border-gray-200 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/30">
                    <td>
                      <strong><code>{field.name}</code></strong>
                    </td>
                    <td>
                      {field.description}
                    </td>
                    <td>
                      {
                        typeof field.type === 'string' ? (
                          field.type === 'integer' ? (
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-semibold bg-blue-100/80 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-200 dark:border-blue-800/50">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="inline w-3.5 h-3.5 align-middle mr-1" stroke-width="0"><path d="M13.003 7.754a.75.75 0 0 1 .75-.75h5.232a.75.75 0 0 1 .53 1.28l-2.776 2.777c.55.097 1.057.253 1.492.483.905.477 1.504 1.284 1.504 2.418 0 .966-.471 1.75-1.172 2.27-.687.511-1.587.77-2.521.77-1.367 0-2.274-.528-2.667-.756a.75.75 0 0 1 .755-1.297c.331.193.953.553 1.912.553.673 0 1.243-.188 1.627-.473.37-.275.566-.635.566-1.067 0-.5-.219-.836-.703-1.091-.538-.284-1.375-.443-2.471-.443a.75.75 0 0 1-.53-1.28l2.643-2.644h-3.421a.75.75 0 0 1-.75-.75ZM7.88 15.215a1.4 1.4 0 0 0-1.446.83.75.75 0 0 1-1.37-.61 2.899 2.899 0 0 1 2.986-1.71c.589.06 1.139.323 1.557.743.434.446.685 1.058.685 1.778 0 1.641-1.254 2.437-2.12 2.986-.538.341-1.18.694-1.495 1.273H9.75a.75.75 0 0 1 0 1.5h-4a.75.75 0 0 1-.75-.75c0-1.799 1.337-2.63 2.243-3.21 1.032-.659 1.55-1.031 1.55-1.8 0-.355-.116-.584-.26-.732a1.071 1.071 0 0 0-.652-.298Zm.234-13.121a.75.75 0 0 1 .386.656V9h1.252a.75.75 0 0 1 0 1.5H5.75a.75.75 0 0 1 0-1.5H7V4.103l-.853.533a.749.749 0 1 1-.795-1.272l2-1.25a.749.749 0 0 1 .762-.02Z"/></svg>
                              <span class="mt-0.5">integer</span>
                            </span>
                          ) : field.type === 'string' ? (
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-semibold bg-emerald-100/80 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300 border border-emerald-200 dark:border-emerald-800/50">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline w-3.5 h-3.5 align-middle mr-1"><path d="m2 16 4.039-9.69a.5.5 0 0 1 .923 0L11 16"/><path d="M22 9v7"/><path d="M3.304 13h6.392"/><circle cx="18.5" cy="12.5" r="3.5"/></svg>
                              string
                            </span>
                          ) : field.type === 'boolean' ? (
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-semibold bg-amber-100/80 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300 border border-amber-200 dark:border-amber-800/50">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline w-3.5 h-3.5 align-middle mr-1"><rect x="14" y="14" width="4" height="6" rx="2"/><rect x="6" y="4" width="4" height="6" rx="2"/><path d="M6 20h4"/><path d="M14 10h4"/><path d="M6 14h2v6"/><path d="M14 4h2v6"/></svg>
                              <span class="mt-0.5">boolean</span>
                            </span>
                          ) : (
                            <span class="inline-flex items-center gap-1.5 flex-wrap">
                              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-semibold bg-purple-100/80 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300 border border-purple-200 dark:border-purple-800/50">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline w-3.5 h-3.5 align-middle mr-1"><path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5c0 1.1.9 2 2 2h1"/><path d="M16 21h1a2 2 0 0 0 2-2v-5c0-1.1.9-2 2-2a2 2 0 0 1-2-2V5a2 2 0 0 0-2-2h-1"/></svg>
                                <span class="mt-0.5">object</span>
                              </span>
                              <a href={`#${field.type}`} class="type-link mb-0.5">{field.type}</a>
                            </span>
                          )
                        ) : (
                          field.type.type === 'list' ? (
                            field.type.of && typeof field.type.of === 'object' ? (
                              <span class="inline-flex items-center gap-1.5 flex-wrap">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-semibold bg-indigo-100/80 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300 border border-indigo-200 dark:border-indigo-800/50">
                                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline w-3.5 h-3.5 align-middle mr-1"><path d="M16 3h3a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1h-3"/><path d="M8 21H5a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h3"/></svg>
                                  <span class="mt-0.5">list</span>
                                </span>
                                <span class="text-slate-400 dark:text-slate-500 text-xs">of</span>
                                <div href={`#${field.type.of.type}`} class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-semibold bg-purple-100/80 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300 border border-purple-200 dark:border-purple-800/50">
                                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline w-3.5 h-3.5 align-middle mr-1"><path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5c0 1.1.9 2 2 2h1"/><path d="M16 21h1a2 2 0 0 0 2-2v-5c0-1.1.9-2 2-2a2 2 0 0 1-2-2V5a2 2 0 0 0-2-2h-1"/></svg>
                                  <a href={`#${field.type.of.type}`} class="type-link hover:underline mt-0.5">
                                    {field.type.of.type}
                                  </a>
                                  &nbsp;
                                  <a href={`#${field.type.of.of}`} class="type-link hover:underline mt-0.5">
                                    [{field.type.of.of}]
                                  </a>
                                </div>
                              </span>
                            ) : (
                              <span class="inline-flex items-center gap-1.5 flex-wrap">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-semibold bg-indigo-100/80 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300 border border-indigo-200 dark:border-indigo-800/50">
                                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline w-3.5 h-3.5 align-middle mr-1"><path d="M16 3h3a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1h-3"/><path d="M8 21H5a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h3"/></svg>
                                  <span class="mt-0.5">list</span>
                                </span>
                                <span class="text-slate-400 dark:text-slate-500 text-xs">of</span>
                                <a href={`#${field.type.of}`} class="type-link mb-0.5 text-sm">{field.type.of}</a>
                              </span>
                            )
                          ) : (
                            <span class="inline-flex items-center gap-1.5 flex-wrap">
                              <div href={`#${field.type.type}`} class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-semibold bg-purple-100/80 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300 border border-purple-200 dark:border-purple-800/50">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline w-3.5 h-3.5 align-middle mr-1"><path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5c0 1.1.9 2 2 2h1"/><path d="M16 21h1a2 2 0 0 0 2-2v-5c0-1.1.9-2 2-2a2 2 0 0 1-2-2V5a2 2 0 0 0-2-2h-1"/></svg>
                                <a href={`#${field.type.type}`} class="type-link hover:underline mt-0.5">
                                  {field.type.type}
                                </a>
                                &nbsp;
                                <a href={`#${field.type.of}`} class="type-link hover:underline mt-0.5">
                                  [{field.type.of}]
                                </a>
                              </div>
                            </span>
                          )
                        )
                      }
                    </td>
                  </tr>))
              }
            </tbody>
          </table>
        ))
      }
    </section>
  ))
}

<style>
  .type-link {
    color: var(--sl-color-accent) !important;
    text-decoration: none !important;
    font-weight: 600 !important;
    transition: color 0.15s ease !important;
  }
  .type-link:hover {
    color: var(--sl-color-accent-high) !important;
    text-decoration: underline !important;
  }
</style>
