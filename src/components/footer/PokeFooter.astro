---
import Pagination from "@astrojs/starlight/components/Pagination.astro";
import FooterBrand from "./FooterBrand.astro";
import FooterNav from "./FooterNav.astro";
import FooterStatus from "./FooterStatus.astro";
import ScrollNextIndicator from "./ScrollNextIndicator.astro";

const currentYear = new Date().getFullYear();

import "./poke-footer.css";
---

<nav class="py-12 pb-4">
  <Pagination />
</nav>

<footer
  class="relative overflow-hidden bg-[var(--sl-color-black)] border-t border-transparent [border-image:linear-gradient(90deg,transparent,var(--sl-color-accent)_30%,var(--pokemon-yellow)_60%,transparent)_1] mt-0"
>
  <div class="footer-bg" aria-hidden="true">
    <div class="bg-blob bg-blob-1"></div>
    <div class="bg-blob bg-blob-2"></div>
    <div class="bg-blob bg-blob-3"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto py-14 px-8 pb-8 max-[600px]:py-8 max-[600px]:px-5 max-[600px]:pb-5">
    <div class="grid grid-cols-1 md:grid-cols-[1.4fr_2fr] gap-12 mb-10 max-[600px]:gap-6 max-[600px]:mb-6">
      <FooterBrand />
      <FooterNav />
    </div>

    <FooterStatus />

    <div
      class="h-[1px] bg-[linear-gradient(90deg,transparent,var(--sl-color-gray-5)_20%,var(--sl-color-gray-5)_80%,transparent)] mb-6"
      aria-hidden="true"
    >
    </div>

    <div class="flex flex-col gap-1 items-center text-center">
      <p class="text-[0.78rem] text-[var(--sl-color-gray-3)] m-0 leading-normal">
        &copy; {currentYear} Created by <a
          class="text-[var(--sl-color-gray-2)] no-underline hover:text-[var(--sl-color-accent-high)] transition-colors duration-150 ease-in-out"
          href="https://github.com/phalt"
          target="_blank"
          rel="noopener"><strong>Paul Hallett</strong></a
        > and <a
          class="text-[var(--sl-color-gray-2)] no-underline hover:text-[var(--sl-color-accent-high)] transition-colors duration-150 ease-in-out"
          href="https://github.com/PokeAPI/pokeapi/graphs/contributors"
          target="_blank"
          rel="noopener">PokéAPI contributors</a
        > around the world.
      </p>
      <p class="text-[0.78rem] text-[var(--sl-color-gray-3)] m-0 leading-normal">
        Pokémon and Pokémon character names are trademarks of Nintendo.
      </p>
    </div>
  </div>
</footer>

<ScrollNextIndicator />

<script src="./footer-status.js"></script>

<script src="./starlight-openapi-custom.js"></script>

<script>
  import "./continuous-scroll.js";
</script>
