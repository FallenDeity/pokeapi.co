---
import Pagination from "@astrojs/starlight/components/Pagination.astro";
import FooterBrand from "./FooterBrand.astro";
import FooterNav from "./FooterNav.astro";
import FooterStatus from "./FooterStatus.astro";
import ScrollNextIndicator from "./ScrollNextIndicator.astro";

const currentYear = new Date().getFullYear();

import "./poke-footer.css";
---

<nav class="pagination-wrapper">
  <Pagination />
</nav>

<footer class="poke-footer">
  <div class="footer-bg" aria-hidden="true">
    <div class="bg-blob bg-blob-1"></div>
    <div class="bg-blob bg-blob-2"></div>
    <div class="bg-blob bg-blob-3"></div>
  </div>

  <div class="footer-content">
    <div class="footer-top">
      <FooterBrand />
      <FooterNav />
    </div>

    <FooterStatus />

    <div class="footer-divider" aria-hidden="true"></div>

    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {currentYear} Created by <a href="https://github.com/phalt" target="_blank" rel="noopener"
          ><strong>Paul Hallett</strong></a
        > and <a href="https://github.com/PokeAPI/pokeapi/graphs/contributors" target="_blank" rel="noopener"
          >PokéAPI contributors</a
        > around the world.
      </p>
      <p class="footer-disclaimer">Pokémon and Pokémon character names are trademarks of Nintendo.</p>
    </div>
  </div>
</footer>

<ScrollNextIndicator />

<script src="./footer-status.js"></script>

<script src="./starlight-openapi-custom.js"></script>

<script>
  import "./continuous-scroll.js";
</script>
