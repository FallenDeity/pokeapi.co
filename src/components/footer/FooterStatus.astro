<div
  class="footer-status bg-[color-mix(in_srgb,var(--sl-color-gray-6)_60%,transparent)] border border-[var(--sl-color-gray-5)] rounded-xl p-5 mb-7 backdrop-blur-md"
>
  <div class="flex items-center gap-2 mb-4">
    <span
      class="status-header-dot w-2 h-2 rounded-full bg-[var(--sl-color-gray-3)] shrink-0 transition-colors duration-300 ease-in-out"
      id="footer-global-dot"
      aria-hidden="true"></span>
    <h4 class="text-[0.78rem] font-semibold tracking-wide uppercase text-[var(--sl-color-gray-2)] m-0 flex-1">
      System Status
    </h4>
    <a
      href="https://pokeapi.statuspage.io/"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-1.25 text-[0.75rem] text-[var(--sl-color-accent)] no-underline hover:text-[var(--sl-color-accent-high)] transition-colors duration-150 ease-in-out whitespace-nowrap"
    >
      View full status
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15,3 21,3 21,9"
        ></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg
      >
    </a>
  </div>

  <div class="flex flex-wrap gap-2 mb-3.5 items-center" id="footer-shields-row">
    <a
      href="https://pokeapi.statuspage.io/"
      target="_blank"
      rel="noopener noreferrer"
      class="shield-link master-shield inline-flex items-center no-underline rounded-md overflow-hidden hover:opacity-85 hover:-translate-y-0.5 transition duration-150 ease-in-out leading-[0]"
      id="footer-master-shield"
      aria-label="Overall system status"
    >
      <img
        src="https://img.shields.io/badge/dynamic/json?style=flat&color=brightgreen&label=status&query=%24.status.description&url=https%3A%2F%2Fzlfyqp3hlvly.statuspage.io%2Fapi%2Fv2%2Fsummary.json"
        alt="Overall system status"
        class="h-5 w-auto block"
        loading="lazy"
        decoding="async"
      />
    </a>

    <a
      href="https://pokeapi.co/api/v2/"
      target="_blank"
      rel="noopener noreferrer"
      class="shield-link inline-flex items-center no-underline rounded-md overflow-hidden hover:opacity-85 hover:-translate-y-0.5 transition duration-150 ease-in-out leading-[0]"
      id="footer-latency-shield"
      aria-label="API response time"
      title="Live response time measured from your browser"
    >
      <img
        src="https://img.shields.io/badge/response_time-...-lightgrey?style=flat"
        alt="API response time"
        class="h-5 w-auto block"
        id="footer-latency-img"
        loading="lazy"
        decoding="async"
      />
    </a>
  </div>
</div>
