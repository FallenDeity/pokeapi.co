---
const baseUrl = import.meta.env.BASE_URL;
const thisUrl = Astro.url.pathname;
const about = baseUrl + "about/";
const v2 = baseUrl + "v2/";
const openapi = baseUrl + "v2/openapi/";
const graphql = baseUrl + "graphql/";
---

<nav class="poke-nav">
  <ul class="nav-list">
    <li class="nav-item">
      {
        thisUrl !== about ? (
          <a href={about} class="nav-link">
            About
          </a>
        ) : (
          <span class="nav-link nav-link--active">About</span>
        )
      }
    </li>
    <li class="nav-item">
      {
        thisUrl !== v2 ? (
          <a href={v2} class="nav-link">
            API v2
          </a>
        ) : (
          <span class="nav-link nav-link--active">API v2</span>
        )
      }
    </li>
    <li class="nav-item">
      {
        thisUrl !== graphql ? (
          <a href={graphql} class="nav-link">
            GraphQL v1Beta
          </a>
        ) : (
          <span class="nav-link nav-link--active">GraphQL v1Beta</span>
        )
      }
    </li>
  </ul>
</nav>

<style>
  .poke-nav {
    display: flex;
    align-items: center;
  }

  .nav-list {
    display: flex;
    gap: 0.125rem;
    list-style: none;
    margin: 0;
    padding: 0 1rem 0 0;
  }

  .nav-link {
    display: inline-block;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-decoration: none !important;
    color: var(--sl-color-gray-2);
    transition:
      color 0.18s ease,
      background 0.18s ease;
    white-space: nowrap;
    position: relative;
  }

  a.nav-link:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-5);
    text-decoration: none !important;
  }

  a.nav-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
    color: var(--sl-color-white);
  }

  .nav-link--active {
    color: var(--sl-color-white);
    background: transparent;
    cursor: default;
    user-select: none;
    pointer-events: none;
    font-weight: 600;
  }

  .nav-link--active::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 0.7rem;
    right: 0.7rem;
    height: 2px;
    border-radius: 1px;
    background: var(--sl-color-accent);
  }
</style>
